{
  "name": "rally",
  "version": "0.1.0",
  "private": true,
  "description": "A single-page army-list builder engine for tabletop wargames. Ships one game as a swappable GAME pack; LaserStorm is the first.",
  "type": "module",
  "scripts": {
    "build": "node build.mjs",
    "check": "node tools/build_check.mjs",
    "serve": "python3 -m http.server 3001 --directory dist",
    "studio": "python3 -m http.server 3001",
    "golden": "APP_URL=http://localhost:3001/index.html node tools/golden_master.cjs /tmp/rally_golden.json",
    "render": "APP_URL=http://localhost:3001/index.html node tools/render_master.cjs /tmp/rally_render.json",
    "functional": "APP_URL=http://localhost:3001/index.html node tools/functional.cjs"
  },
  "devDependencies": {
    "playwright": "^1.40.0"
  }
}
